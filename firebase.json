{
  "hosting": {
    "site": "kobeydev",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".firebase/**",
      "**/.*",
      "README.md",
      "LICENSE"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.@(css|js|svg|woff2)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  }
}
